# Переменные окружения для деплоя (Railway → вкладка Variables).
# Скопируйте в .env для локальной разработки (python-dotenv не требуется — задайте в окружении).

# ОБЯЗАТЕЛЬНО в проде: секрет для подписи сессий (32+ случайных байта).
#   сгенерировать: python -c "import secrets; print(secrets.token_hex(32))"
ABS_SECRET_KEY=change-me-to-a-long-random-string

# Пароль администратора при ПЕРВОМ наполнении базы (по умолчанию admin123).
ABS_ADMIN_PASSWORD=change-me

# Каталог для данных (SQLite + загрузки). На Railway смонтируйте том и укажите его путь,
# чтобы контент и заявки переживали редеплой. Например: /data
DATA_DIR=/data

# Включить отладчик Flask (НЕ для прода). 1 — включить.
# FLASK_DEBUG=0

# Принудительно Secure-cookie за HTTPS-прокси (на Railway включается автоматически).
# ABS_HTTPS=1

# Необязательно: внешняя БД вместо SQLite (например, плагин PostgreSQL на Railway).
# При использовании добавьте psycopg2-binary в requirements.txt.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
